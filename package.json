    "webpack-dev-middleware": "^7.2.1",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.6",
    "@angular-devkit/core": "^22.0.6",
    "@angular/build": "^22.0.6",
    "@angular-devkit/schematics": "^22.0.6",
    "@angular/cli": "^22.0.6",
