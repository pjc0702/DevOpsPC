{
  "name": "dev-ops-pc",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "version": "echo $npm_package_version",
    "name": "echo $npm_package_name",
    "dockerRegistry": "echo $npm_package_publishConfig_dockerRegistry",
    "test:unit": "ng test --no-watch --browsers=ChromeHeadless --no-progress",
    "cover": "ng test --watch=false --code-coverage=true",
    "build:ci": "ng build --configuration production --aot --build-optimizer --progress=false --base-href ./"
  },
  "publishConfig": {
    "registry": "https://cdnxpro.pronaca.com/repository/npm-hosted/",
    "dockerRegistry": "cddnpro.pronaca.com"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.6",
    "@angular/build": "^22.0.6",
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone-peer-dep": "^2.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/instrumentation": "^0.220.0",
